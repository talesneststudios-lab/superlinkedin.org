# LinkedIn OAuth 2.0 credentials
# Get these from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Two-host setup: marketing site on www, app/dashboard on app.
# Anything in /app, /auth, /api, /checkout, /billing, /onboarding, /upgrade, /playbook, /logout is routed to APP_HOST.
# Everything else (landing page, marketing pages) is routed to MARKETING_HOST.
APP_HOST=app.superlinkedin.org
MARKETING_HOST=www.superlinkedin.org

# Cookie scope: must be the parent domain so sessions span both subdomains
COOKIE_DOMAIN=.superlinkedin.org

# Optional - kept for backwards compatibility; current code prefers APP_HOST/MARKETING_HOST above.
# BASE_URL=https://app.superlinkedin.org

# Session secret (generate a random string)
SESSION_SECRET=replace_with_a_random_secret_string_here

# Server port
PORT=3000

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# Stripe Price IDs (create products at https://dashboard.stripe.com/products)
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_ADVANCED_MONTHLY=price_xxx
STRIPE_PRICE_ADVANCED_YEARLY=price_xxx
STRIPE_PRICE_ULTRA_MONTHLY=price_xxx
STRIPE_PRICE_ULTRA_YEARLY=price_xxx

# OpenAI (for AI post generation)
OPENAI_API_KEY=sk-your-openai-api-key-here

# RapidAPI (for Inspiration post search)
RAPIDAPI_KEY=your-rapidapi-key-here

# AWS DynamoDB
AWS_REGION=us-east-1
DYNAMODB_TABLE=superlinkedin-users
DYNAMODB_SESSIONS_TABLE=superlinkedin-sessions
