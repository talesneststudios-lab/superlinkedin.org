{
  "manifest_version": 3,
  "name": "SuperLinkedIn",
  "description": "LinkedIn analytics, AI post writer, engagement tracking, post scheduler and growth tools in your feed.",
  "version": "2.0.4",
  "permissions": ["storage", "activeTab", "alarms", "tabs", "scripting"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://linkedin.com/*",
    "https://*.superlinkedin.org/*",
    "https://superlinkedin.org/*",
    "https://*.awsapprunner.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*", "https://linkedin.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.superlinkedin.org/*",
        "https://superlinkedin.org/*",
        "https://*.awsapprunner.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
